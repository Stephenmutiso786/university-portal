NODE_ENV=production
PORT=4000
JWT_SECRET=replace-with-a-long-random-secret
TRUST_PROXY=true
CORS_ORIGIN=https://portal.example.com,https://www.portal.example.com
MAX_BODY_SIZE=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
STORAGE_ENGINE=prisma
DATA_FILE=/app/backend/data/store.json
DATABASE_URL=postgresql://portal_user:portal_password@postgres:5432/university_portal?schema=public
